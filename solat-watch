#!/usr/bin/env bash
# Background azan notifier - checks every 60s, macOS notification at prayer time
set -euo pipefail

CACHE_DIR="$HOME/.cache/solat"
mkdir -p "$CACHE_DIR"

NAMES=(Fajr Dhuhr Asr Maghrib Isha)
LABELS=(Subuh Zohor Asar Maghrib Isyak)

LAST_DATE=""

while true; do
  TODAY=$(date +%Y%m%d)
  TIMINGS_FILE="$CACHE_DIR/timings-$TODAY.json"
  NOTIFIED_FILE="$CACHE_DIR/notified-$TODAY"

  if [[ "$TODAY" != "$LAST_DATE" ]]; then
    LOC=$(curl -s ipinfo.io/json)
    CITY=$(echo "$LOC" | jq -r '.city')
    COUNTRY=$(echo "$LOC" | jq -r '.country')
    echo "$CITY $COUNTRY" > "$CACHE_DIR/location"
    curl -sL "https://api.aladhan.com/v1/timingsByCity?city=$(echo "$CITY" | sed 's/ /%20/g')&country=${COUNTRY}&method=17" > "$TIMINGS_FILE"
    find "$CACHE_DIR" -name 'timings-*.json' ! -name "timings-$TODAY.json" -delete
    find "$CACHE_DIR" -name 'notified-*' ! -name "notified-$TODAY" -delete
    LAST_DATE="$TODAY"
  fi

  touch "$NOTIFIED_FILE"
  NOW=$(date +%H:%M)
  for i in "${!NAMES[@]}"; do
    T=$(jq -r ".data.timings.${NAMES[$i]}" "$TIMINGS_FILE" | cut -d' ' -f1)
    if [[ "$NOW" == "$T" ]] && ! grep -qx "${NAMES[$i]}" "$NOTIFIED_FILE"; then
      osascript -e "display notification \"${LABELS[$i]} - waktu solat\" with title \"Azan\" sound name \"Glass\""
      echo "${NAMES[$i]}" >> "$NOTIFIED_FILE"
    fi
  done

  sleep 60
done
